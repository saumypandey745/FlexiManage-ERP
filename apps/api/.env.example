# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://admin:admin_password@localhost:5432/fleximanage_dev?schema=public"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Security (JWT)
JWT_SECRET="super_secret_jwt_key_must_be_long_in_production"
JWT_EXPIRES_IN="15m"
REFRESH_SECRET="super_secret_refresh_key_must_be_long_in_production"
REFRESH_EXPIRES_IN="7d"

# External Services
STRIPE_API_KEY=""
SENDGRID_API_KEY=""
OPENAI_API_KEY=""
