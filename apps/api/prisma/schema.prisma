  EXCEL
  PDF
  JSON
}

enum WidgetType {
  CHART
  TABLE
  KPI_CARD
  MAP
  TIMELINE
}

enum AggregationType {
  SUM
  COUNT
  AVERAGE
  MIN
  MAX
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MetricType {
  REVENUE
  EXPENSE
  USER_COUNT
  RETENTION
  CONVERSION
  PERFORMANCE
  OTHER
}

