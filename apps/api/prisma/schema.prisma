  iv             String      @db.VarChar(255)
  
  expiresAt      DateTime?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model HubWebhookEndpoint {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  url            String      @db.VarChar(1000)
  secret         String?     @db.VarChar(255)
  events         String[]
  isActive       Boolean     @default(true)
  
  deliveries     HubWebhookDelivery[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model HubWebhookDelivery {
  id                String      @id @default(uuid()) @db.Uuid
  endpointId        String      @db.Uuid
  endpoint          HubWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  
  eventType         String      @db.VarChar(255)
  payload           Json
  status            String      @default("PENDING") // PENDING, SUCCESS, FAILED
  attempts          Int         @default(0)
  nextAttemptAt     DateTime?
  lastResponseCode  Int?
  
  logs              HubWebhookLog[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model HubWebhookLog {
  id                String      @id @default(uuid()) @db.Uuid
  deliveryId        String      @db.Uuid
  delivery          HubWebhookDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  
  attemptNumber     Int
  responseCode      Int?
  responseBody      String?     @db.Text
  error             String?     @db.Text
  durationMs        Int?

  createdAt         DateTime    @default(now())
}

model SyncJob {
  id             String      @id @default(uuid()) @db.Uuid
  integrationId  String      @db.Uuid
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  entityType     String      @db.VarChar(100) // INVOICE, LEAD, CALENDAR
  direction      String      @db.VarChar(20)  // INBOUND, OUTBOUND
  status         String      @default("PENDING") // PENDING, IN_PROGRESS, SUCCESS, FAILED
  
  logs           SyncLog[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model SyncLog {
  id             String      @id @default(uuid()) @db.Uuid
  jobId          String      @db.Uuid
  job            SyncJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  level          String      @db.VarChar(20) // INFO, WARN, ERROR
  message        String      @db.Text
  details        Json?

  createdAt      DateTime    @default(now())
}

model IntegrationAudit {
  id             String      @id @default(uuid()) @db.Uuid
  integrationId  String      @db.Uuid
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  userId         String?     @db.Uuid
  action         String      @db.VarChar(100)
  details        Json?

  createdAt      DateTime    @default(now())
}


model SaaSSubscriptionPlan {
  id             String    @id @default(uuid()) @db.Uuid
  
  name           String    @db.VarChar(100) // FREE, STARTER, PRO, ENTERPRISE
  description    String?   @db.Text
  price          Decimal   @db.Decimal(10, 2)
  currency       String    @db.VarChar(3) @default("USD")
  interval       String    @db.VarChar(20) // MONTHLY, YEARLY
  
  features       SaaSPlanFeature[]
  subscriptions  SaaSSubscription[]
  meteredFeatures SaaSPlanMeteredFeature[]

  isActive       Boolean   @default(true)
  version        Int       @default(1)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
}

model SaaSPlanFeature {
  id             String    @id @default(uuid()) @db.Uuid
  planId         String    @db.Uuid
  plan           SaaSSubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  key            String    @db.VarChar(100) // USERS, STORAGE, PROJECTS
  value          String    @db.VarChar(255) // "10", "UNLIMITED", "100GB"
  limit          Int?      // Null means unlimited or boolean

  createdAt      DateTime  @default(now())
}

model SaaSPlanMeteredFeature {
  id             String    @id @default(uuid()) @db.Uuid
  planId         String    @db.Uuid
  plan           SaaSSubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  key            String    @db.VarChar(100) // API_CALLS, AI_TOKENS
  pricePerUnit   Decimal   @db.Decimal(10, 4)
  freeUnits      Int       @default(0)

  createdAt      DateTime  @default(now())
}

model SaaSSubscription {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid @unique
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  planId         String    @db.Uuid
  plan           SaaSSubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  
  status         String    @db.VarChar(50) // ACTIVE, CANCELED, PAST_DUE, TRIALING
  
  trialStartsAt  DateTime?
  trialEndsAt    DateTime?
  
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  
  cancelAtPeriodEnd Boolean @default(false)
  canceledAt        DateTime?
  
  provider       String?   @db.VarChar(50) // STRIPE, RAZORPAY
  providerSubId  String?   @db.VarChar(255)
  
  usages         SaaSUsageRecord[]
  invoices       SaaSInvoice[]

  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
}

model SaaSSubscriptionUsage {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  key            String    @db.VarChar(100)
  currentUsage   Int       @default(0)
  lastResetAt    DateTime

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([tenantId, key])
}

model SaaSUsageRecord {
  id             String    @id @default(uuid()) @db.Uuid
  subscriptionId String    @db.Uuid
  subscription   SaaSSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  featureKey     String    @db.VarChar(100)
  quantity       Int
  timestamp      DateTime  @default(now())
  
  providerReported Boolean @default(false)
}

model SaaSCoupon {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String?   @db.Uuid // Nullable for global coupons
  
  code           String    @db.VarChar(50) @unique
  discountType   String    @db.VarChar(20) // PERCENTAGE, FIXED
  discountValue  Decimal   @db.Decimal(10, 2)
  
  maxUses        Int?
  uses           Int       @default(0)
  
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean   @default(true)

  createdAt      DateTime  @default(now())
}

model SaaSInvoice {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  subscriptionId String?   @db.Uuid
  subscription   SaaSSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  
  amount         Decimal   @db.Decimal(10, 2)
  currency       String    @db.VarChar(3) @default("USD")
  
  status         String    @db.VarChar(50) // DRAFT, OPEN, PAID, UNCOLLECTIBLE, VOID
  
  pdfUrl         String?   @db.VarChar(1000)
  
  providerInvId  String?   @db.VarChar(255)
  
  items          SaaSInvoiceItem[]
  transactions   SaaSPaymentTransaction[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SaaSInvoiceItem {
  id             String    @id @default(uuid()) @db.Uuid
  invoiceId      String    @db.Uuid
  invoice        SaaSInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description    String    @db.VarChar(255)
  amount         Decimal   @db.Decimal(10, 2)
  quantity       Int       @default(1)

  createdAt      DateTime  @default(now())
}

model SaaSPaymentTransaction {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  invoiceId      String?   @db.Uuid
  invoice        SaaSInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  
  provider       String    @db.VarChar(50) // STRIPE, RAZORPAY, PAYPAL
  providerTxId   String    @db.VarChar(255) @unique
  
  amount         Decimal   @db.Decimal(10, 2)
  currency       String    @db.VarChar(3) @default("USD")
  
  status         String    @db.VarChar(50) // REQUIRES_PAYMENT_METHOD, SUCCEEDED, FAILED
  method         String?   @db.VarChar(50) // CARD, BANK_TRANSFER
  
  receiptUrl     String?   @db.VarChar(1000)
  
  refunds        SaaSRefund[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SaaSRefund {
  id             String    @id @default(uuid()) @db.Uuid
  transactionId  String    @db.Uuid
  transaction    SaaSPaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  amount         Decimal   @db.Decimal(10, 2)
  reason         String?   @db.VarChar(255)
  status         String    @db.VarChar(50) // PENDING, SUCCEEDED, FAILED

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SaaSBillingAudit {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  action         String    @db.VarChar(100) // UPGRADE, CANCEL, PAYMENT_FAILED
  details        Json?
  userId         String?   @db.Uuid

  createdAt      DateTime  @default(now())
}
