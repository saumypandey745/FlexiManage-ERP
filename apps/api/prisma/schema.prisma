  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String?      @db.Uuid
  action         ActionType
  entityName     String       @db.VarChar(100)
  entityId       String       @db.Uuid
  oldValues      Json?
  newValues      Json?
  createdAt      DateTime     @default(now())
  @@index([tenantId, entityName])
  @@map("audit_logs")
}


// ==========================================
// INVENTORY & WAREHOUSE MODULE
// ==========================================

enum WarehouseStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  CLOSED
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  RETURN
}

model Warehouse {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(255)
  location       String?      @db.Text
  capacity       Int          @default(0)
  status         WarehouseStatus @default(ACTIVE)

  managerId      String?      @db.Uuid
  manager        User?        @relation("WarehouseManager", fields: [managerId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  stockItems     StockItem[]
  movementsFrom  StockMovement[] @relation("MovementFromWarehouse")
  movementsTo    StockMovement[] @relation("MovementToWarehouse")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("inv_warehouses")
}

model ProductCategory {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name           String       @db.VarChar(100)
  description    String?      @db.Text
  parentId       String?      @db.Uuid
  parent         ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       ProductCategory[] @relation("CategoryHierarchy")

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  products       Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("inv_product_categories")
}

model ProductVariant {
  id             String       @id @default(uuid()) @db.Uuid
  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku            String       @db.VarChar(100)
  name           String       @db.VarChar(255)
  options        Json?        

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([productId, sku])
  @@map("inv_product_variants")
}

model Supplier {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(255)
  code           String       @db.VarChar(50)
  email          String?      @db.VarChar(255)
  phone          String?      @db.VarChar(50)
  address        String?      @db.Text
  rating         Int          @default(0)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("inv_suppliers")
}

model StockItem {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  warehouseId    String       @db.Uuid
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity       Int          @default(0)
  reserved       Int          @default(0)
  batchNumber    String?      @db.VarChar(100)
  expiryDate     DateTime?    @db.Date

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([warehouseId, productId, batchNumber])
  @@index([tenantId])
  @@map("inv_stock_items")
}

model StockMovement {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type           MovementType
  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id])

  fromWarehouseId String?     @db.Uuid
  fromWarehouse  Warehouse?   @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id])

  toWarehouseId  String?      @db.Uuid
  toWarehouse    Warehouse?   @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id])

  quantity       Int
  reference      String?      @db.VarChar(100)
  notes          String?      @db.Text

  performedById  String       @db.Uuid
  performedBy    User         @relation("MovementPerformer", fields: [performedById], references: [id])

  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@map("inv_stock_movements")
}

model PurchaseOrder {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  poNumber       String       @db.VarChar(50)
  supplierId     String       @db.Uuid
  supplier       Supplier     @relation(fields: [supplierId], references: [id])

  status         POStatus     @default(DRAFT)
  totalAmount    Decimal      @db.Decimal(12, 2)
  expectedDate   DateTime?    @db.Date

  createdById    String       @db.Uuid
  createdBy      User         @relation("POCreator", fields: [createdById], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  lines          PurchaseOrderLine[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("inv_purchase_orders")
}

model PurchaseOrderLine {
  id             String       @id @default(uuid()) @db.Uuid
  poId           String       @db.Uuid
  po             PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id])

  quantity       Int
  received       Int          @default(0)
  unitPrice      Decimal      @db.Decimal(12, 2)

  @@map("inv_purchase_order_lines")
}

// ==========================================
// PROJECT & TASK MANAGEMENT MODULE
// ==========================================

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}



enum TaskType {
  BUG
  FEATURE
  EPIC
  STORY
  TASK
}

enum DependencyType {
  BLOCKS
  IS_BLOCKED_BY
  RELATES_TO
  DUPLICATES
}

enum SprintStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum ReminderType {
  EMAIL
  IN_APP
  PUSH
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Project {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(255)
  code           String       @db.VarChar(50)
  description    String?      @db.Text
  status         ProjectStatus @default(PLANNING)
  priority       ProjectPriority @default(MEDIUM)
  
  startDate      DateTime?    @db.Date
  endDate        DateTime?    @db.Date
  budget         Decimal?     @db.Decimal(15, 2)
  progress       Int          @default(0) // 0-100 percentage
  
  customerId     String?      @db.Uuid
  customer       Customer?    @relation(fields: [customerId], references: [id])
  
  members        ProjectMember[]
  tasks          Task[]
  milestones     Milestone[]
  sprints        Sprint[]
  files          ProjectFile[]
  statusHistory  ProjectStatusHistory[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  version        Int          @default(1)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("pm_projects")
}

model ProjectMember {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  projectId      String       @db.Uuid
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id])
  
  role           String       @default("MEMBER") @db.VarChar(50)
  billableRate   Decimal?     @db.Decimal(10, 2)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([projectId, userId])
  @@index([tenantId])
  @@map("pm_project_members")
}

model Milestone {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  projectId      String       @db.Uuid
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(255)
  description    String?      @db.Text
  dueDate        DateTime     @db.Date
  isCompleted    Boolean      @default(false)
  
  tasks          Task[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@map("pm_milestones")
}

model Sprint {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  projectId      String       @db.Uuid
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(100)
  goal           String?      @db.Text
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  status         SprintStatus @default(PLANNED)
  
  tasks          Task[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@map("pm_sprints")
}

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  projectId      String       @db.Uuid
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  code           String       @db.VarChar(50)
  title          String       @db.VarChar(255)
  description    String?      @db.Text
  
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  type           TaskType     @default(TASK)
  
  assigneeId     String?      @db.Uuid
  assignee       User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId     String       @db.Uuid
  reporter       User         @relation("TaskReporter", fields: [reporterId], references: [id])
  
  milestoneId    String?      @db.Uuid
  milestone      Milestone?   @relation(fields: [milestoneId], references: [id])
  
  sprintId       String?      @db.Uuid
  sprint         Sprint?      @relation(fields: [sprintId], references: [id])
  
  parentTaskId   String?      @db.Uuid
  parentTask     Task?        @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks       Task[]       @relation("SubTasks")
  
  startDate      DateTime?    @db.Date
  dueDate        DateTime?    @db.Date
  completedAt    DateTime?
  
  estimatedHours Decimal?     @db.Decimal(10, 2)
  actualHours    Decimal?     @db.Decimal(10, 2)
  
  comments       TaskComment[]
  attachments    TaskAttachment[]
  checklists     TaskChecklist[]
  labels         TaskLabel[]
  activities     TaskActivity[]
  timeEntries    TimeEntry[]
  statusHistory  TaskStatusHistory[]
  watchers       TaskWatcher[]
  reminders      TaskReminder[]
  
  dependencies     TaskDependency[] @relation("TaskDependsOn")
