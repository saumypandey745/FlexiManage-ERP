generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "tracing", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  LOCKED
  SUSPENDED
  ARCHIVED
}

enum EmployeeStatus {
  ONBOARDING
  PROBATION
  CONFIRMED
  NOTICE_PERIOD
  TERMINATED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  NEEDS_ANALYSIS
  VALUE_PROPOSITION
  DECISION_MAKERS
  PERCEPTION_ANALYSIS
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  CONVERTED
  LOST
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
}

model Tenant {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(255)
  status         TenantStatus @default(TRIAL)
  subscription   SubscriptionPlan @default(FREE)
  timezone       String       @default("UTC")
  currency       String       @default("USD")
  
  profile        OrganizationProfile?
  users          User[]
  roles          Role[]
  employees      Employee[]
  customers      Customer[]
  leads          Lead[]
  contacts       Contact[]
  opportunities  Opportunity[]
  products       Product[]
  invoices       Invoice[]
  auditLogs      AuditLog[]
  branches       Branch[]
  departments    Department[]
  teams          Team[]

  warehouses          Warehouse[]
  productCategories   ProductCategory[]
  suppliers           Supplier[]
  stockItems          StockItem[]
  stockMovements      StockMovement[]
  purchaseOrders      PurchaseOrder[]

  payments            Payment[]
  expenseCategories   ExpenseCategory[]
  expenseClaims       ExpenseClaim[]
  ledgerAccounts      LedgerAccount[]
  journalEntries      JournalEntry[]
  taxRates            TaxRate[]

  employeeProfiles    EmployeeProfile[]
  attendances         Attendance[]
  leaveTypes          LeaveType[]
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  holidays            Holiday[]
  shifts              Shift[]
  employeeShifts      EmployeeShift[]
  payrolls            Payroll[]
  candidates          RecruitmentCandidate[]
  interviews          Interview[]
  jobPositions        JobPosition[]

  projects            Project[]
  projectMembers      ProjectMember[]
  milestones          Milestone[]
  sprints             Sprint[]
  tasks               Task[]
  taskComments        TaskComment[]
  taskAttachments     TaskAttachment[]
  taskChecklists      TaskChecklist[]
  taskLabels          TaskLabel[]
  taskActivities      TaskActivity[]
  timeEntries         TimeEntry[]
  projectStatusHistory ProjectStatusHistory[]
  taskStatusHistory   TaskStatusHistory[]
  taskDependencies    TaskDependency[]
  taskWatchers        TaskWatcher[]
  taskReminders       TaskReminder[]
  projectFiles        ProjectFile[]
  projectTemplates    ProjectTemplate[]
  taskNotifications   TaskNotification[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("tenants")
  notifications    Notification[]
  notificationPreferences NotificationPreference[]
  notificationTemplates NotificationTemplate[]
  emailLogs        EmailLog[]
  smsLogs          SmsLog[]
  pushNotifications PushNotification[]
  inAppNotifications InAppNotification[]
  webhooks         Webhook[]
  chatRooms        ChatRoom[]
  announcements    Announcement[]
  notificationQueues NotificationQueue[]
  communicationAudits CommunicationAudit[]


  reports                 Report[]
  reportTemplates         ReportTemplate[]
  dashboards              Dashboard[]
  dashboardWidgets        DashboardWidget[]
  savedFilters            SavedFilter[]
  scheduledReports        ScheduledReport[]
  reportExecutions        ReportExecution[]
  reportExports           ReportExport[]
  kpiSnapshots            KpiSnapshot[]
  metricDefinitions       MetricDefinition[]
  analyticsEvents         AnalyticsEvent[]
  reportShares            ReportShare[]
  reportSubscriptions     ReportSubscription[]
  reportAudits            ReportAudit[]


  aiProviders             AiProvider[]
  aiPromptTemplates       AiPromptTemplate[]
  aiConversations         AiConversation[]
  aiConversationMessages  AiConversationMessage[]
  aiUsages                AiUsage[]
  aiDocuments             AiDocument[]
  aiEmbeddings            AiEmbedding[]
  aiAudits                AiAudit[]


  workflows               Workflow[]
  workflowNodes           WorkflowNode[]
  workflowEdges           WorkflowEdge[]
  workflowExecutions      WorkflowExecution[]
  workflowVariables       WorkflowVariable[]
  workflowLogs            WorkflowLog[]


  folders                 Folder[]
  documents               Document[]
  documentVersions        DocumentVersion[]
  documentShares          DocumentShare[]
  documentMetadata        DocumentMetadata[]
  documentTags            DocumentTag[]
  documentComments        DocumentComment[]
  documentLocks           DocumentLock[]
  documentAudits          DocumentAudit[]


  integrations            Integration[]
  hubWebhookEndpoints HubWebhookEndpoint[]




  saasSubscription            SaaSSubscription?
  saasSubscriptionUsages      SaaSSubscriptionUsage[]
  saasSubscriptionInvoices    SaaSInvoice[]
  saasPaymentTransactions     SaaSPaymentTransaction[]
  saasBillingAudits           SaaSBillingAudit[]

}

model OrganizationProfile {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @unique @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalName      String       @db.VarChar(255)
  businessEmail  String?      @db.VarChar(255)
  phone          String?      @db.VarChar(50)
  gstNumber      String?      @db.VarChar(50)
  panNumber      String?      @db.VarChar(50)
  country        String       @default("US")
  address        String?      @db.Text
  logoUrl        String?      @db.VarChar(255)
  brandingColor  String?      @db.VarChar(50)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  version        Int          @default(1)

  @@map("organization_profiles")
}

model Branch {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(100)
  isHeadOffice   Boolean      @default(false)
  address        String?      @db.Text
  phone          String?      @db.VarChar(50)
  email          String?      @db.VarChar(255)
  
  departments    Department[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  version        Int          @default(1)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model Department {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String?      @db.Uuid
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(100)
  description    String?      @db.Text
  
  teams          Team[]
  employees      Employee[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  version        Int          @default(1)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model Team {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departmentId   String?      @db.Uuid
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(100)
  description    String?      @db.Text

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  version        Int          @default(1)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("teams")
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  email          String       @db.VarChar(255)
  passwordHash   String       @db.VarChar(255)
  status         UserStatus   @default(INVITED)
  
  roles          UserRole[]
  employee       Employee?
  profile        UserProfile?
  preference     UserPreference?
  
  assignedLeads         Lead[]        @relation("LeadAssignee")
  assignedCustomers     Customer[]    @relation("CustomerAssignee")
  assignedOpportunities Opportunity[] @relation("OpportunityAssignee")

  managedWarehouses     Warehouse[]       @relation("WarehouseManager")
  performedMovements    StockMovement[]   @relation("MovementPerformer")
  createdPOs            PurchaseOrder[]   @relation("POCreator")

  expenseClaims       ExpenseClaim[]    @relation("UserExpenses")

  projectMemberships  ProjectMember[]
  assignedTasks       Task[]            @relation("TaskAssignee")
  reportedTasks       Task[]            @relation("TaskReporter")
  taskComments        TaskComment[]
  uploadedFiles       TaskAttachment[]
  taskActivities      TaskActivity[]
  timeEntries         TimeEntry[]
  projectStatusChanges ProjectStatusHistory[]
  taskStatusChanges   TaskStatusHistory[]
  watchedTasks        TaskWatcher[]
  taskReminders       TaskReminder[]
  uploadedProjectFiles ProjectFile[]
  taskNotifications   TaskNotification[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
  sentNotifications Notification[] @relation("NotificationSender")
  receivedNotifications NotificationRecipient[] @relation("NotificationReceiver")
  notificationPreferences NotificationPreference[] @relation("NotificationPrefs")
  pushNotifications PushNotification[]
  inAppNotifications InAppNotification[]
  chatParticipants ChatParticipant[]
  sentMessages     ChatMessage[] @relation("MessageSender")
  messageReactions MessageReaction[]
  publishedAnnouncements Announcement[] @relation("AnnouncementPublisher")
  receivedAnnouncements AnnouncementRecipient[] @relation("AnnouncementReceiver")
  commAudits       CommunicationAudit[] @relation("CommAuditUser")


  createdReports          Report[]


  aiConversations         AiConversation[]
  aiUsages                AiUsage[]
  aiAudits                AiAudit[]


  documentComments        DocumentComment[]
  documentLocks           DocumentLock[]

}

model UserProfile {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @unique @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String?      @db.VarChar(100)
  lastName       String?      @db.VarChar(100)
  phone          String?      @db.VarChar(50)
  avatarUrl      String?      @db.VarChar(255)
  bio            String?      @db.Text

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("user_profiles")
}

model UserPreference {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @unique @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  timezone       String       @default("UTC")
  language       String       @default("en")
  theme          String       @default("system")
  notifications  Boolean      @default(true)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("user_preferences")
}

model Role {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String?      @db.Uuid
  tenant         Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String       @db.VarChar(100)
  
  users          UserRole[]
  permissions    RolePermission[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id             String       @id @default(uuid()) @db.Uuid
  action         String       @db.VarChar(100)
  roles          RolePermission[]

  @@unique([action])
  @@map("permissions")
}

model UserRole {
  userId         String       @db.Uuid
  roleId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId         String       @db.Uuid
  permissionId   String       @db.Uuid
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission     Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================
// HRMS MODULE
// ==========================================

enum PayrollStatus {
  DRAFT
  PROCESSING
  PAID
  FAILED
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEWING
  OFFERED
  HIRED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ShiftType {
  MORNING
  EVENING
  NIGHT
  CUSTOM
}

model Employee {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String?      @unique @db.Uuid
  user           User?        @relation(fields: [userId], references: [id], onDelete: Restrict)
  employeeCode   String       @db.VarChar(50)
  firstName      String       @db.VarChar(100)
  lastName       String       @db.VarChar(100)
  status         EmployeeStatus @default(ONBOARDING)
  managerId      String?      @db.Uuid
  manager        Employee?    @relation("ManagerToEmployee", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates   Employee[]   @relation("ManagerToEmployee")

  departmentId   String?      @db.Uuid
  department     Department?  @relation(fields: [departmentId], references: [id])

  profile        EmployeeProfile?
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  shifts         EmployeeShift[]
  payrolls       Payroll[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  version        Int          @default(1)

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@map("hrm_employees")
}

model EmployeeProfile {
  id             String       @id @default(uuid()) @db.Uuid
  employeeId     String       @unique @db.Uuid
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  phone          String?      @db.VarChar(50)
  address        String?      @db.Text
  dateOfBirth    DateTime?    @db.Date
  joiningDate    DateTime?    @db.Date

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_employee_profiles")
}

model Attendance {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  employeeId     String       @db.Uuid
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  date           DateTime     @db.Date
  clockIn        DateTime
  clockOut       DateTime?
  status         AttendanceStatus @default(PRESENT)
  isLate         Boolean      @default(false)
  
  breaks         AttendanceBreak[]

  @@unique([tenantId, employeeId, date])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_attendances")
}

model AttendanceBreak {
  id             String       @id @default(uuid()) @db.Uuid
  attendanceId   String       @db.Uuid
  attendance     Attendance   @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  
  startTime      DateTime
  endTime        DateTime?
  type           String       @db.VarChar(50)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_attendance_breaks")
}

model LeaveType {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(50)
  defaultDays    Int
  isPaid         Boolean      @default(true)

  leaveBalances  LeaveBalance[]
  leaveRequests  LeaveRequest[]

  @@unique([tenantId, name])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_leave_types")
}

model LeaveBalance {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  employeeId     String       @db.Uuid
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  leaveTypeId    String       @db.Uuid
  leaveType      LeaveType    @relation(fields: [leaveTypeId], references: [id])
  
  year           Int
  totalDays      Decimal      @db.Decimal(5, 2)
  usedDays       Decimal      @db.Decimal(5, 2) @default(0)

  @@unique([tenantId, employeeId, leaveTypeId, year])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_leave_balances")
}

model LeaveRequest {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  employeeId     String       @db.Uuid
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  leaveTypeId    String       @db.Uuid
  leaveType      LeaveType    @relation(fields: [leaveTypeId], references: [id])
  
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  status         LeaveStatus  @default(PENDING)
  reason         String?      @db.Text
  
  approvedById   String?      @db.Uuid

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_leave_requests")
}

model Holiday {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(100)
  date           DateTime     @db.Date
  isRecurring    Boolean      @default(false)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_holidays")
}

model Shift {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(50)
  type           ShiftType    @default(MORNING)
  startTime      String       @db.VarChar(10) // "09:00"
  endTime        String       @db.VarChar(10) // "17:00"
  gracePeriod    Int          @default(15) // minutes

  employeeShifts EmployeeShift[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_shifts")
}

model EmployeeShift {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  employeeId     String       @db.Uuid
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  shiftId        String       @db.Uuid
  shift          Shift        @relation(fields: [shiftId], references: [id])
  
  startDate      DateTime     @db.Date
  endDate        DateTime?    @db.Date

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_employee_shifts")
}

model Payroll {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  employeeId     String       @db.Uuid
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  month          Int
  year           Int
  status         PayrollStatus @default(DRAFT)
  
  basicSalary    Decimal      @db.Decimal(12, 2)
  netSalary      Decimal      @db.Decimal(12, 2)
  
  items          PayrollItem[]

  @@unique([tenantId, employeeId, month, year])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_payrolls")
}

model PayrollItem {
  id             String       @id @default(uuid()) @db.Uuid
  payrollId      String       @db.Uuid
  payroll        Payroll      @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(100)
  amount         Decimal      @db.Decimal(12, 2)
  type           String       @db.VarChar(20) // "EARNING", "DEDUCTION"

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_payroll_items")
}

model RecruitmentCandidate {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  firstName      String       @db.VarChar(100)
  lastName       String       @db.VarChar(100)
  email          String       @db.VarChar(255)
  phone          String?      @db.VarChar(50)
  status         CandidateStatus @default(APPLIED)
  
  positionId     String       @db.Uuid
  position       JobPosition  @relation(fields: [positionId], references: [id])
  
  interviews     Interview[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_recruitment_candidates")
}

model JobPosition {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  title          String       @db.VarChar(100)
  description    String?      @db.Text
  isOpen         Boolean      @default(true)
  
  candidates     RecruitmentCandidate[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_job_positions")
}

model Interview {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  candidateId    String       @db.Uuid
  candidate      RecruitmentCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  interviewerId  String       @db.Uuid // Usually an Employee ID
  scheduledAt    DateTime
  status         InterviewStatus @default(SCHEDULED)
  feedback       String?      @db.Text

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@map("hrm_interviews")
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name           String       @db.VarChar(255)
  industry       String?      @db.VarChar(100)
  email          String?      @db.VarChar(255)
  phone          String?      @db.VarChar(50)
  website        String?      @db.VarChar(255)
  billingAddress String?      @db.Text
  shippingAddress String?     @db.Text

