enum NotificationType {
  SYSTEM
  ALERT
  REMINDER
  MESSAGE
  ANNOUNCEMENT
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  READ
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum WebhookStatus {
  ACTIVE
  INACTIVE
  FAILED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DeliveryStatus {
